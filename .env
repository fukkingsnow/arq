# Database Configuration
DB_NAME=arq_development
DB_USER=arq_dev
DB_PASSWORD=arq_dev_password
DB_PORT=5433

# Redis Configuration
DB_PORT5433
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# FastAPI Settings
DEBUG=False
HOST=0.0.0.0
PORT=8000
APP_PORT=8000

# OpenAI / LLM Settings
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4
TEMPERATURE=0.7
MAX_TOKENS=2000

# Memory Settings
MEMORY_BATCH_SIZE=10
MEMORY_TTL_SECONDS=86400
MAX_CONTEXT_MESSAGES=20

# Telegram Bot (Optional)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_ID=your_bot_id_here

# Beget API Settings
BEGET_API_URL=https://cp.beget.com/api
BEGET_API_KEY=your_beget_api_key_here

# Application Settings
DATABASE_URL=postgresql+asyncpg://arq_dev:arq_dev_password@arq-postgres-dev:5432/arq_development
