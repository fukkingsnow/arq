{
  "name": "arq",
  "version": "1.1.0",
  "description": "Advanced Request Queue - High-performance task processing system",
  "author": "fukkingsnow",
  "license": "MIT",
  "scripts": {
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "build:watch": "nest build --watch",
    "start:dev:opt": "npm run build:watch & npm run start:dev",
    "build:prod": "nest build --webpack --webpackPath webpack-hmr.config.js",
    "commit:src": "git add src/ && git commit -m",
    "deploy:optimized": "npm run build:prod && git push",
    "lint": "eslint src --fix",
    "lint:strict": "eslint src --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "build:frontend": "cd src/frontend && npm install && npm run build",
    "copy:frontend": "mkdir -p dist && cp -r src/frontend dist/frontend",
    "audit:fix": "npm audit fix --force",
    "audit:strict": "npm audit --audit-level=moderate",
    "quality:fix": "npm run lint -- --fix && npm audit fix",
    "build:webpack": "nest build"
  },
  "dependencies": {
    "@nestjs/bull": "11.0.4",
    "@nestjs/common": "11.0.1",
    "@nestjs/config": "4.0.0",
    "@nestjs/core": "11.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/serve-static": "5.0.1",
    "@nestjs/swagger": "11.0.0",
    "@nestjs/typeorm": "11.0.0",
    "@nestjs/websockets": "11.0.1",
    "@octokit/rest": "22.0.1",
    "axios": "1.13.5",
    "bcrypt": "6.0.0",
    "bull": "4.16.5",
    "bullmq": "5.70.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "compression": "1.8.1",
    "dockerode": "4.0.9",
    "dotenv": "17.3.1",
    "eventemitter2": "6.4.9",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "ioredis": "5.9.3",
    "joi": "18.0.2",
    "nodemailer": "8.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "path": "0.12.7",
    "pg": "8.18.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.28",
    "typeorm-naming-strategies": "4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.14",
    "@types/bcrypt": "6.0.0",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/multer": "2.0.0",
    "@types/node": "25.3.0",
    "@types/nodemailer": "7.0.11",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.1",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  }
}
